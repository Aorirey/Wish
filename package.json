{
  "name": "wishly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "node scripts/start.js",
    "start:next": "next start -p ${PORT:-3000} -H 0.0.0.0",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "db:deploy": "prisma db push --accept-data-loss && npm run db:seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "autoprefixer": "10.4.20",
    "clsx": "2.1.1",
    "framer-motion": "11.11.1",
    "lucide-react": "0.447.0",
    "next": "14.2.15",
    "postcss": "8.4.47",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.13",
    "tailwind-merge": "2.5.2",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@types/node": "20.16.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.15",
    "prisma": "5.22.0",
    "tsx": "4.19.4",
    "typescript": "5.6.2"
  }
}
